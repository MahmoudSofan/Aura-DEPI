# Copy to .env and fill in real values. Never commit .env.

# --- OpenRouter (unified LLM + image gateway) ---
# OpenRouter API key — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...
# OpenRouter API base URL (override only for self-hosted gateways).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Chat model used by the copy and critic stages. OpenRouter routes models with
# a `provider/model` prefix — see https://openrouter.ai/models
AURA_LLM_MODEL=openai/gpt-4o-mini

# Image model used by the image stage. OpenRouter routes image generation
# through `/chat/completions` with `modalities=["image","text"]` (it does
# NOT expose `/images/generations`). Pick a chat-image-capable model:
#   - google/gemini-2.5-flash-image-preview  (cheap, ~$0.039/image)
#   - openai/gpt-image-1                     (sharper, ~$0.17/image)
AURA_IMAGE_MODEL=google/gemini-2.5-flash-image

# --- Search / web tools (degradable per FR-021) ---
# Tavily API key — https://app.tavily.com/
# Leave blank to exercise the degradable-research path.
TAVILY_API_KEY=tvly-...

# --- ChromaDB (used by /healthz and the retrieval stage) ---
# From the host (default for `uvicorn`): localhost / 8001 (the host port the
# compose stack exposes).
# From inside docker compose's `api` service: chromadb / 8000 (the internal
# service name + container port — already wired in docker-compose.yml).
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Tracking ---
# MLflow tracking server. Use http://localhost:5000 from the host,
# http://mlflow:5000 from inside the compose network.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=aura

# --- Aura runtime config ---
# Critic pass threshold — overall score must reach this to "pass".
AURA_CRITIC_THRESHOLD=0.7
# Maximum number of automatic creative+image retries after a failed critic.
AURA_RETRY_CAP=2
# Maximum number of simultaneously executing runs (queue beyond this).
AURA_CONCURRENCY_CAP=5
# Per-brand retention cap for terminal runs; oldest are pruned beyond this.
AURA_RUN_RETENTION_PER_BRAND=100
# Root directory for SQLite, uploads, and artifacts.
AURA_DATA_DIR=backend/data

# --- API auth (optional) ---
# Leave blank to disable bearer-token enforcement (default: open on localhost).
AURA_API_TOKEN=

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
