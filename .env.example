# Copy to .env and fill in real values. Never commit .env.

# --- LLM providers ---
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Search / web tools ---
# Tavily API key — https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# --- Hugging Face ---
# HF user access token — https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
